APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://newsbot:newsbot@postgres:5432/newsbot
POSTGRES_DB=newsbot
POSTGRES_USER=newsbot
POSTGRES_PASSWORD=newsbot

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH=/models/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# LLM is served by the local pi coding agent (spawned as a subprocess).
LLM_PROVIDER=pi
PI_BIN=pi
# Optional: force a provider/model for pi. Leave empty to use pi's configured defaults.
PI_PROVIDER=
PI_THINKING=
PI_TIMEOUT_SECONDS=300
LLM_SMART_MODEL=
LLM_CHEAP_MODEL=
LLM_TEMPERATURE=0.1

# OAuth for pi: mount your host pi config dir containing auth.json here and run
#   docker compose run --rm app python scripts/init_oauth.py pi --import-auth
# PI_HOST_AUTH_DIR points at a host directory containing auth.json (defaults to ./pi-auth).
PI_HOST_AUTH_DIR=./pi-auth
PI_AUTH_JSON_PATH=/host_pi_auth/auth.json

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION_PATH=/secrets/telethon.session
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Optional: when set, non-health API routes require Authorization: Bearer <token>
API_OWNER_TOKEN=

GMAIL_CLIENT_SECRET_PATH=/secrets/gmail_client_secret.json
GMAIL_TOKEN_PATH=/secrets/gmail_token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

SOURCE_CONFIG_PATH=/config/sources.yaml
TRUSTED_SOURCES_PATH=/config/trusted_sources.yaml
TRUSTED_SOCIAL_ACCOUNTS_PATH=/config/trusted_social_accounts.yaml

FETCH_TIMEOUT_SECONDS=20
MAX_LINK_DEPTH=2
MIN_TRUSTED_DOCUMENTS=1
ALLOW_X_OFFICIAL_POSTS=true
REJECT_TELEGRAM_LINKS=true
REJECT_FACEBOOK_LINKS=true
REQUIRE_ENGLISH=true
